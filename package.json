{
  "name": "ai-chat-widget",
  "version": "1.0.0",
  "description": "AI-powered chat bot for website embedding, built with Express, PostgreSQL and OpenAI API",
  "repository": "https://github.com/lierzillah/ai-chat-example-nodejs",
  "author": "Andrey Dubchak <a.dubchak.virtue@gmail.com>",
  "type": "commonjs",
  "dependencies": {
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "ejs": "^4.0.1",
    "express": "^5.2.1",
    "nodemon": "^3.1.11",
    "openai": "^6.21.0",
    "pg": "^8.18.0",
    "prettier": "^3.8.1",
    "sequelize": "^6.37.7"
  },
  "scripts": {
    "start": "sequelize db:migrate && nodemon server.js",
    "migrate": "sequelize-cli db:migrate --config config/config.js",
    "migrate-undo": "sequelize db:migrate:undo",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "sequelize-cli": "^6.6.5"
  }
}
